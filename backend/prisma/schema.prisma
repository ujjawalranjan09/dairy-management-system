generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  phone      String   @default("") @map("phone")
  email      String?  @unique
  password   String
  name       String
  role       String   @default("ADMIN")   // ADMIN | EMPLOYEE | CUSTOMER
  ownerId    Int?     @map("owner_id")    // For EMPLOYEE and CUSTOMER: references the business ADMIN
  customerId Int?     @unique @map("customer_id") // For CUSTOMER role: links this login to a specific Customer record

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations for data ownership (ADMIN is the owner)
  customers Customer[]
  products  Product[]
  purchases Purchase[]
  payments  Payment[]

  // Self-relation: business owner (ADMIN) <-> employees/customers
  owner     User?  @relation("BusinessUsers", fields: [ownerId], references: [id], onDelete: SetNull)
  employees User[] @relation("BusinessUsers")

  // Link to Customer record for CUSTOMER role users
  linkedCustomer Customer? @relation("CustomerPortalUser", fields: [customerId], references: [id])

  creatorCustomers Customer[] @relation("CreatorCustomers")
  creatorPurchases Purchase[] @relation("CreatorPurchases")
  creatorPayments  Payment[]  @relation("CreatorPayments")

  // Customers assigned to this employee
  assignedCustomers Customer[] @relation("AssignedEmployee")

  // New relations
  stockEntries  Stock[]
  advancePayments AdvancePayment[]

  @@index([ownerId])
  @@index([customerId])
  @@map("users")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phoneNumber String   @map("phone_number")
  address     String?
  userId      Int      @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Default product settings for this customer
  defaultProducts CustomerDefaultProduct[]

  // Assigned employee (for routing purposes - but others can still enter)
  assignedEmployeeId Int? @map("assigned_employee_id")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  payments  Payment[]

  // Assigned employee relation
  assignedEmployee User? @relation("AssignedEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  // Portal login for this customer (CUSTOMER role user)
  portalUser User? @relation("CustomerPortalUser")

  creatorId   Int?     @map("creator_id")
  creator     User?    @relation("CreatorCustomers", fields: [creatorId], references: [id], onDelete: SetNull)

  // New relations
  advancePayments AdvancePayment[]

  @@index([userId])
  @@index([creatorId])
  @@index([assignedEmployeeId])
  @@map("customers")
}

model Product {
  id          Int      @id @default(autoincrement())
  productName String   @map("product_name")
  price       Decimal
  unit        String
  userId      Int      @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  // Customers who have this as default product
  defaultForCustomers CustomerDefaultProduct[]

  // New relations
  stockEntries Stock[]

  @@index([userId])
  @@map("products")
}

model Purchase {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  productId  Int      @map("product_id")
  quantity   Float
  price      Decimal
  date       DateTime
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  shift      String   @default("MORNING")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  creatorId  Int?     @map("creator_id")
  creator    User?    @relation("CreatorPurchases", fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([productId])
  @@index([date])
  @@index([userId])
  @@index([creatorId])
  @@map("purchases")
}

model Payment {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  amount      Decimal
  month       Int
  year        Int
  paymentDate DateTime? @map("payment_date")
  status      String   @default("PENDING")
  method      String   @default("CASH")
  userId      Int      @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  creatorId   Int?     @map("creator_id")
  creator     User?    @relation("CreatorPayments", fields: [creatorId], references: [id], onDelete: SetNull)

  @@unique([customerId, month, year, userId])
  @@index([customerId])
  @@index([month, year])
  @@index([userId])
  @@index([creatorId])
  @@map("payments")
}

model CustomerDefaultProduct {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  productId  Int      @map("product_id")
  quantity   Float
  unit       String

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
  @@map("customer_default_products")
}

// NEW: Stock/Inventory tracking
model Stock {
  id           Int      @id @default(autoincrement())
  date         DateTime
  productId    Int      @map("product_id")
  openingQty   Float    @default(0) @map("opening_qty")
  receivedQty  Float    @default(0) @map("received_qty")
  soldQty      Float    @default(0) @map("sold_qty")
  wastedQty    Float    @default(0) @map("wasted_qty")
  closingQty   Float    @default(0) @map("closing_qty")
  userId       Int      @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([date, productId, userId])
  @@index([date])
  @@index([productId])
  @@index([userId])
  @@map("stock")
}

// NEW: Advance payments
model AdvancePayment {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  amount      Decimal
  remaining   Decimal
  date        DateTime
  method      String   @default("CASH")
  note        String?  @default("")
  userId      Int      @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
  @@map("advance_payments")
}
